generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String   @default("User")
  passwordHash String
  createdAt    DateTime @default(now())

  assets   Asset[]
  folders  Folder[]
  audios   Audio[]
  videos   Video[]
  sessions GenerationSession[]
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  assets Asset[]
}

model Asset {
  id         String   @id @default(cuid())
  filename   String
  storageKey String   @default("")
  url        String
  size       Int      @default(0)
  uploadedAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id], onDelete: Cascade)

  videos         Video[]
  sessionAssets  SessionAsset[]
}

model Audio {
  id            String   @id @default(cuid())
  title         String
  artist        String   @default("")
  filename      String
  coverFilename String?
  coverUrl      String?
  duration      Float    @default(0)
  url           String
  uploadedAt    DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  videos   Video[]
  sessions GenerationSession[]
}

model GenerationSession {
  id          String   @id @default(cuid())
  name        String?
  index       Int      @default(0)
  durationMs  Int
  fadeInMs    Int      @default(0)
  fadeOutMs   Int      @default(0)
  createdAt   DateTime @default(now())

  audioId String?
  audio   Audio?  @relation(fields: [audioId], references: [id], onDelete: SetNull)

  presetId String
  preset   VideoPreset @relation(fields: [presetId], references: [id])

  assets SessionAsset[]
  videos Video[]

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SessionAsset {
  sessionId String
  assetId   String

  session GenerationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  asset   Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([sessionId, assetId])
  @@index([assetId])
}

model Video {
  id           String      @id @default(cuid())
  title        String
  phrase       String
  status       VideoStatus @default(QUEUED)
  videoUrl     String?
  thumbnailUrl String?
  errorMessage String?
  createdAt    DateTime    @default(now())
  startedAt    DateTime?
  completedAt  DateTime?

  sessionId String?
  session   GenerationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  presetId String
  preset   VideoPreset @relation(fields: [presetId], references: [id])

  assetId        String?
  asset          Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)
  sourceImageUrl String  @default("")

  audioId        String?
  audio          Audio?  @relation(fields: [audioId], references: [id], onDelete: SetNull)
  sourceAudioUrl String  @default("")

  durationMs  Int    @default(30000)
  fadeInMs    Int    @default(0)
  fadeOutMs   Int    @default(0)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([sessionId])
  @@index([status])
}

enum VideoStatus {
  QUEUED
  GENERATING
  COMPLETED
  FAILED
}

enum VideoFormat {
  LANDSCAPE_16_9 @map("16:9")
  STANDARD_4_3   @map("4:3")
  SQUARE_1_1     @map("1:1")
  PORTRAIT_3_4   @map("3:4")
  VERTICAL_9_16  @map("9:16")
}

model VideoPreset {
  id          String      @id
  name        String
  description String?
  format      VideoFormat
  component   String
  width       Int
  height      Int
  fps         Int         @default(30)
  createdAt   DateTime    @default(now())

  sessions GenerationSession[]
  videos   Video[]
}
