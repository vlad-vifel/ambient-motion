{
  "name": "ambient-motion",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api,worker -c cyan,magenta,yellow \"npm run dev --workspace=apps/web\" \"npm run dev --workspace=apps/api\" \"npm run worker --workspace=apps/api\"",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:worker": "npm run worker --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "build:api": "npm run build --workspace=apps/api",
    "lint": "eslint . --fix --ext .ts,.tsx,.vue,.js,.jsx",
    "format": "prettier --write \"apps/**/*.{vue,ts,tsx,js,jsx,css}\"",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "apps/**/*.{vue,ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "apps/**/*.{css,json,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "vue-eslint-parser": "^10.4.0"
  }
}
